<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainLayout" xmlns:fx="http://javafx.com/fxml" fx:controller="com.hotel.controller.MainController" styleClass="root">
    <left>
        <StackPane fx:id="sidebar" prefWidth="210.0" minWidth="170.0" maxWidth="210.0" BorderPane.alignment="CENTER_LEFT">
            <children>
                <StackPane fx:id="sidebarBackground" styleClass="sidebar">
                    <children>
                        <ImageView fx:id="sidebarBgView" fitWidth="210.0" preserveRatio="false" pickOnBounds="true">
                            <image>
                                <Image url="@images/sidebar-bg.jpg"/>
                            </image>
                        </ImageView>
                        <VBox style="-fx-background-color: rgba(0,0,0,0.78);" />
                    </children>
                </StackPane>
                <VBox fx:id="sidebarContent" spacing="0.0" fillWidth="true">
                    <children>
                        <VBox styleClass="sidebar-header" spacing="5.0">
                            <children>
                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <children>
                                        <ImageView fx:id="logoView" fitWidth="36.0" fitHeight="36.0" preserveRatio="true">
                                            <image>
                                                <Image url="@images/logo.png" />
                                            </image>
                                        </ImageView>
                                        <VBox spacing="2.0">
                                            <children>
                                                <Label text="HotelPro" styleClass="sidebar-title" />
                                                <Label text="MANAGEMENT SYSTEM" styleClass="sidebar-subtitle" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                            <padding>
                                <Insets top="24" right="16" bottom="20" left="16" />
                            </padding>
                        </VBox>

                        <Region style="-fx-background-color: rgba(201,168,76,0.25); -fx-pref-height: 1px;" />

                        <VBox spacing="2.0">
                            <padding>
                                <Insets top="14" right="0" bottom="10" left="0" />
                            </padding>
                            <children>
                                <Button fx:id="dashboardButton" text="  ◈  Dashboard" maxWidth="1.7976931348623157E308" styleClass="nav-button" onAction="#showDashboard" />
                                <Button fx:id="roomsButton" text="  ⊞  Rooms" maxWidth="1.7976931348623157E308" styleClass="nav-button" onAction="#showRooms" />
                                <Button fx:id="customersButton" text="  ◉  Customers" maxWidth="1.7976931348623157E308" styleClass="nav-button" onAction="#showCustomers" />
                                <Button fx:id="bookingsButton" text="  ▣  Bookings" maxWidth="1.7976931348623157E308" styleClass="nav-button" onAction="#showBookings" />
                                <Button fx:id="billingButton" text="  ◆  Billing" maxWidth="1.7976931348623157E308" styleClass="nav-button" onAction="#showBilling" />
                            </children>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />

                        <Label text="v1.0.0  ·  HotelPro" styleClass="sidebar-version">
                            <padding>
                                <Insets top="0" right="0" bottom="16" left="15" />
                            </padding>
                        </Label>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </left>

    <center>
        <ScrollPane fx:id="contentScroll" fitToWidth="true" fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED" styleClass="scroll-pane">
            <content>
                <StackPane fx:id="contentWrapper" styleClass="content-area">
                    <padding>
                        <Insets top="22" right="22" bottom="22" left="22" />
                    </padding>
                </StackPane>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
